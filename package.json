{
  "name": "whatsoup",
  "version": "0.1.0",
  "description": "WhatSoup — consolidated WhatsApp platform with embedded MCP tools",
  "type": "module",
  "engines": {
    "node": ">=23.10.0"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts",
    "start:instance": "node --experimental-strip-types src/bootstrap.ts",
    "fleet": "node --experimental-strip-types src/fleet/standalone.ts 9099",
    "setup": "bash deploy/setup.sh",
    "auth": "node --experimental-strip-types src/transport/auth.ts",
    "auth:instance": "node --experimental-strip-types src/bootstrap-auth.ts",
    "strip-types-compat": "bash scripts/strip-types-compat.sh",
    "pretest": "npm run strip-types-compat",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@mozilla/readability": "0.6.0",
    "@pinecone-database/pinecone": "7.1.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "cheerio": "1.2.0",
    "linkedom": "0.18.12",
    "openai": "5.23.2",
    "pdf-parse": "2.4.5",
    "pino": "9.14.0",
    "pino-roll": "4.0.0",
    "qrcode-terminal": "0.12.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/qrcode-terminal": "0.12.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
